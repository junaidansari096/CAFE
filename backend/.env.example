# Environment variables for production backend
# Copy this file to .env and fill in your values

PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/future_brew?retryWrites=true&w=majority
JWT_SECRET=your_strong_random_secret_here_change_me
NODE_ENV=production
FRONTEND_URL=https://your-frontend-url.vercel.app
